# ==============================================================================
# QUANTNUIS EC2 API - ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to .env and update the values
# IMPORTANT: Keep this file secure (chmod 600 .env)
# ==============================================================================

# --- DATABASE ---
# PostgreSQL connection URL
DATABASE_URL=postgresql://quantnuis:CHANGE_ME_IN_PRODUCTION@localhost:5432/quantnuis

# --- SECURITY ---
# JWT Secret Key - MUST be the same as Lambda for token compatibility
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_KEY

# Token expiration in minutes (24 hours = 1440)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS ---
# Comma-separated list of allowed origins
# Example: http://projet-quantnuis-frontend.s3-website.eu-west-3.amazonaws.com,http://localhost:4200
CORS_ORIGINS=http://projet-quantnuis-frontend.s3-website.eu-west-3.amazonaws.com

# --- DEBUG ---
# Set to "true" for development
DEBUG=false
